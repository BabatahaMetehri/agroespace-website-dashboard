# ── Frontend (Vite) ─────────────────────────────────────────────────────
# These are bundled into the public JS — only put PUBLIC anon keys here,
# never service-role keys. Copy to `.env` (which is gitignored) for local dev.

# Main Supabase project — backs the admin console + edge function
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_ANON_KEY=

# Map app — separate Supabase project (public/map/index.html)
# Injected at build time by vite.config.ts → mapEnvInjector
VITE_MAP_SUPABASE_URL=
VITE_MAP_SUPABASE_ANON_KEY=

# ImgBB upload key (used by BlogEditor, Promo, map photo uploads)
VITE_IMGBB_KEY=

# ── Edge Function (Supabase project secrets) ────────────────────────────
# Set these via `supabase secrets set` or the Supabase dashboard, NOT here.
# (Listed for documentation only.)
#
# ADMIN_EMAILS=admin1@agroespace.com,admin2@agroespace.com
# AGROESPACE_API_KEY=<long random string for Logicom integration>
# CORS_ORIGINS=https://agroespace.com,https://www.agroespace.com
